{
  "name": "mentraos-streamer-app",
  "version": "1.0.0",
  "main": "src/server/index.js",
  "scripts": {
    "start": "bun src/server/index.ts",
    "dev": "concurrently \"bun run dev:backend\" \"bun run dev:frontend\"",
    "dev:backend": "bun --watch src/server/index.ts",
    "dev:frontend": "cd src/frontend && bunx --bun vite",
    "build:frontend": "cd src/frontend && bunx --bun vite build",
    "build:frontend:prod": "cd src/frontend && bun install --production && bunx --bun vite build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "",
  "license": "MIT",
  "description": "",
  "dependencies": {
    "@mentra/sdk": "^2.1.21",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "mongoose": "^9.0.0",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.14",
    "@types/ws": "^8.18.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.0.0"
  }
}
